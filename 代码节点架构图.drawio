                <mxCell id="299" value="" style="edgeStyle=none;html=1;" edge="1" parent="1" source="296" target="298">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="296" value="前两条固定保留（system，user task，AI需要始终看到任务要求 ）&lt;div&gt;最近 keepRecent 轮的消息保留完整（AI 做决策需要最新的上下文）&lt;/div&gt;&lt;div&gt;更早的轮次：tool result 超长的截断为摘要，assistant 中间思考也截断&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="1592.5" y="1000" width="375" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="298" value="关键约束：&lt;div&gt;1.不能删除任何消息，因为 API 要求 tool_call 和 tool_result 一一配对&lt;/div&gt;&lt;div&gt;2.不能动 tool_calls中的内容，只截短 content&lt;/div&gt;&lt;div&gt;3.tool result 的 tool_call_id 必须保留&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="1590" y="1140" width="380" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="300" value="通过循环调用执行工具" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="1947" y="240" width="120" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="305" value="" style="edgeStyle=none;html=1;" edge="1" parent="1" source="302" target="304">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="302" value="&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;通过 openai.chat.completions.create&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;的tools参数数组，每个元素是工具的 JSON Schema 定义，包含 name、description（根据这个判断是否要调用这个工具），parameters（参数格式）&lt;/span&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="1650" y="220" width="260" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="304" value="调用后：会往 messages 数组里 push 一条 role: tool 的消息，必须带上 tool_call_id（和 AI 返回的 tool_call 一一配对）然后整个 messages 数组再发给 AI ，AI 看到 工具结果后决定下一步" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="1605" y="100" width="350" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="306" value="我写了四个工具：&lt;div&gt;1. list_directory(&lt;span style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;递归列出目录结构，返回树形文本&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;)&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;2.read_file(读取文件)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;3.write_file(写文件)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;4.search_code(在项目中搜索指定的文本或代码行)&lt;/span&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="2047.25" y="140" width="319.5" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="311" value="" style="edgeStyle=none;html=1;" edge="1" parent="1" source="308" target="310">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="308" value="路径安全：safePath 函数防止路径穿透" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="2147" y="520" width="120" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="310" value="防护方式：&lt;div&gt;1.path.resolve()把 .. 的路径转为绝对路径&lt;/div&gt;&lt;div&gt;2.检查解析出来的路径是否是 workDIr 开头的&lt;/div&gt;&lt;div&gt;3.如果不是的话，直接抛出错误，阻止操作&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="2075.25" y="660" width="263.5" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="312" value="驳回后还原：&lt;div&gt;added-&amp;gt;删除，modified-&amp;gt;用快照覆盖，deleted-&amp;gt;从快照中恢复&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="2500" y="490" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="316" value="通过后：Git 会 push 特性分支 -&amp;gt; 调用 GitHub/GitLab 的 API 创建 PR" style="whiteSpace=wrap;html=1;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="2490" y="240" width="180" height="60" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
